{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "EBNF",
	"scopeName": "source.ebnf",
	"patterns": [
		{ "include": "#comment" },
		{ "include": "#pseudo-rule" },
		{ "include": "#rule" },
		{ "include": "#expression" }
	],
	"repository": {
		"comment": {
			"name": "comment.block.ebnf",
			"begin": "(\\(\\*)",
			"beginCaptures": {
				"1": { "name": "punctuation.definition.comment.begin.ebnf" }
			},
			"end": "(\\*\\))",
			"endCaptures": {
				"1": { "name": "punctuation.definition.comment.end.ebnf" }
			},
			"patterns": [ { "include": "#comment" } ]
		},
		"pseudo-rule": {
			"match": "([a-zA-Z][a-zA-Z0-9-]*)\\s*(=)\\s*(\\?[^?]*\\?)\\s*([;.])",
			"captures": {
				"1": { "name": "entity.name.constant.pseudo-rule.ebnf" },
				"2": { "name": "keyword.operator.assignment.ebnf" },
				"3": { "name": "string.other.special-sequence.ebnf" },
				"4": { "name": "punctuation.terminator.rule.ebnf" }
			}
		},
		"rule": {
			"match": "([a-zA-Z][a-zA-Z0-9-]*)\\s*(=)",
			"captures": {
				"1": { "name": "entity.name.function.rule.ebnf" },
				"2": { "name": "keyword.operator.assignment.ebnf" }
			}
		},
		"expression": {
			"patterns": [
				{ "include": "#comment" },
				{ "include": "#string-single" },
				{ "include": "#string-double" },
				{ "include": "#special-sequence" },
				{ "include": "#terminator" },
				{ "include": "#brackets" },
				{ "include": "#alternation" },
				{ "include": "#concatenation" },
				{ "include": "#except" },
				{ "include": "#repetition-count" },
				{ "include": "#repetition-star" },
				{ "include": "#identifier" }
			]
		},
		"string-single": {
			"name": "string.quoted.single.ebnf",
			"begin": "(')",
			"beginCaptures": {
				"1": { "name": "punctuation.definition.string.begin.ebnf" }
			},
			"end": "(')|(?=\\n)",
			"endCaptures": {
				"1": { "name": "punctuation.definition.string.end.ebnf" }
			}
		},
		"string-double": {
			"name": "string.quoted.double.ebnf",
			"begin": "(\")",
			"beginCaptures": {
				"1": { "name": "punctuation.definition.string.begin.ebnf" }
			},
			"end": "(\")|(?=\\n)",
			"endCaptures": {
				"1": { "name": "punctuation.definition.string.end.ebnf" }
			}
		},
		"special-sequence": {
			"name": "string.other.special-sequence.ebnf",
			"begin": "(\\?)",
			"beginCaptures": {
				"1": { "name": "punctuation.definition.special-sequence.begin.ebnf" }
			},
			"end": "(\\?)",
			"endCaptures": {
				"1": { "name": "punctuation.definition.special-sequence.end.ebnf" }
			}
		},
		"terminator": {
			"name": "punctuation.terminator.rule.ebnf",
			"match": "[;.]"
		},
		"alternation": {
			"name": "keyword.operator.alternation.ebnf",
			"match": "[|/!]"
		},
		"concatenation": {
			"name": "keyword.operator.concatenation.ebnf",
			"match": ","
		},
		"except": {
			"name": "keyword.operator.except.ebnf",
			"match": "-"
		},
		"repetition-count": {
			"match": "(\\d+)\\s*(\\*)",
			"captures": {
				"1": { "name": "constant.numeric.integer.ebnf" },
				"2": { "name": "keyword.operator.repetition.ebnf" }
			}
		},
		"repetition-star": {
			"name": "keyword.operator.repetition.ebnf",
			"match": "\\*"
		},
		"brackets": {
			"patterns": [
				{
					"name": "punctuation.definition.optional.begin.ebnf",
					"match": "\\(/"
				},
				{
					"name": "punctuation.definition.optional.end.ebnf",
					"match": "/\\)"
				},
				{
					"name": "punctuation.definition.repetition.begin.ebnf",
					"match": "\\(:"
				},
				{
					"name": "punctuation.definition.repetition.end.ebnf",
					"match": ":\\)"
				},
				{
					"name": "punctuation.definition.group.begin.ebnf",
					"match": "\\("
				},
				{
					"name": "punctuation.definition.group.end.ebnf",
					"match": "\\)"
				},
				{
					"name": "punctuation.definition.optional.begin.ebnf",
					"match": "\\["
				},
				{
					"name": "punctuation.definition.optional.end.ebnf",
					"match": "\\]"
				},
				{
					"name": "punctuation.definition.repetition.begin.ebnf",
					"match": "\\{"
				},
				{
					"name": "punctuation.definition.repetition.end.ebnf",
					"match": "\\}"
				}
			]
		},
		"identifier": {
			"name": "variable.other.identifier.ebnf",
			"match": "[a-zA-Z][a-zA-Z0-9-]*"
		}
	}
}
