; Musi Language - Formal Grammar (LL(1))
; RFC 5234 ABNF. Maximal munch throughout.
; §0  Terminal pseudo-rules
any     = <any Unicode scalar value>

newline = %x0A  ; LINE FEED
; §1  Lexical grammar
; §1.1  Character classes
letter = %x41-5A  ; A-Z / a-z
         / %x61-7A

digit  = %x30-39  ; 0-9

xdigit = digit  ; 0-9 / A-F / a-f
         / %x41-46
         / %x61-66
; §1.2  Identifiers
ident         = plain-ident
                / escaped-ident

plain-ident   = letter *(letter / digit / "_")

escaped-ident = %x60 *(<any except backtick>) %x60  ; `...`

ty-ident      = "'" letter *(letter / digit / "_")

op-ident      = "(" op-chars ")"

op-chars      = "+"  ; §1.3  Literals
                / "-"
                / "*"
                / "/"
                / "%"
                / "="
                / "/="
                / "<"
                / ">"
                / "<="
                / ">="
                / "<<"
                / ">>"
                / "::"
                / "|>"

lit           = lit-int
                / lit-float
                / lit-string
                / lit-fstring
                / lit-rune

lit-int       = dec-int
                / hex-int
                / oct-int
                / bin-int

dec-int       = digit *(digit / "_")

hex-int       = "0x" xdigit *(xdigit / "_")

oct-int       = "0o" (%x30-37) *(%x30-37 / "_")  ; 0-7

bin-int       = "0b" ("0" / "1") *(("0" / "1") / "_")

lit-float     = *digit "." 1*digit [("e" / "E") ["+" / "-"] 1*digit]

lit-string    = DQUOTE *(str-char) DQUOTE

lit-fstring   = %s"f" DQUOTE *(fstr-part) DQUOTE

lit-rune      = "'" rune-char "'"

fstr-part     = "{" ast-expr "}"
                / str-char

str-char      = "\" any
                / <any except DQUOTE>

rune-char     = "\" any  ; §1.4  Comments
                / <any except single-quote>

comment       = "//" *(<any except newline>)  ; line
                / "///" *(<any except newline>)  ; doc - documents next item
                / "/*" *(<any except "*/">) "*/"  ; block - does not nest
; §1.5  Keywords
keyword        = "and"  ; §1.6  Compound tokens - maximal munch
                 / "as"
                 / "choice"
                 / "class"
                 / "defer"
                 / "do"
                 / "effect"
                 / "export"
                 / "fatal"
                 / "foreign"
                 / "handle"
                 / "if"
                 / "import"
                 / "in"
                 / "instance"
                 / "law"
                 / "let"
                 / "match"
                 / "mut"
                 / "not"
                 / "of"
                 / "or"
                 / "record"
                 / "resume"
                 / "return"
                 / "try"
                 / "where"
                 / "with"
                 / "xor"

compound-token = ":="  ; §2  Parser grammar
                 / "<-"
                 / "->"
                 / "~>"
                 / "=>"
                 / "/="
                 / "<="
                 / ">="
                 / "?."
                 / "!."
                 / ".["
                 / ".{"
                 / "??"
                 / "!!"
                 / ".."
                 / "..<"
                 / "..."
                 / "<<"
                 / ">>"
                 / "::"
                 / "<:"
                 / ":>"
                 / ":?"
                 / ":?>"
                 / "|>"
                 / "#["
; §2.1  Top level
ast-root = *(ast-stmt)

ast-stmt = ast-expr ";"  ; §2.2  Expressions - precedence ladder (lowest -> highest)
;
;   Assignment          <-              right
;   Nil-coalescing      ?? !!           right
;   Pipeline            |>              left
;   Disjunction         or              left
;   Exclusive-or        xor             left
;   Conjunction         and             left
;   Comparison          = /= < > <= >= in   non-assoc
;   Range               .. ..<          non-assoc
;   Cons                ::              right
;   Shift               << >>           left
;   Additive            + -             left
;   Multiplicative      * / %           left
;   Prefix              - not           unary
;   Postfix             () .[] .{} . ?. !. ? ! :? :?>
;
;   and/or/xor/not are type-directed: boolean on Bool, bitwise on integers.
;   No separate & | ^ ~ operators exist.
ast-expr       = ast-expr-coal ["<-" ast-expr]

ast-expr-coal  = ast-expr-pipe [("??" / "!!") ast-expr-coal]

ast-expr-pipe  = ast-expr-disj *("|>" ast-expr-disj)

ast-expr-disj  = ast-expr-xor *("or" ast-expr-xor)

ast-expr-xor   = ast-expr-conj *("xor" ast-expr-conj)

ast-expr-conj  = ast-expr-cmp *("and" ast-expr-cmp)

ast-expr-cmp   = ast-expr-range [("=" / "/=" / "<" / ">" / "<=" / ">=" / "in") ast-expr-range]

ast-expr-range = ast-expr-cons [(".." / "..<") ast-expr-cons]

ast-expr-cons  = ast-expr-sft ["::" ast-expr-cons]

ast-expr-sft   = ast-expr-add *(("<<" / ">>") ast-expr-add)

ast-expr-add   = ast-expr-mul *(("+" / "-") ast-expr-mul)

ast-expr-mul   = ast-expr-pre *(("*" / "/" / "%") ast-expr-pre)

ast-expr-pre   = ("-" / "not") ast-expr-pre
                 / ast-expr-post

ast-expr-post  = ast-expr-atom *(postfix-op)  ; §2.3  Postfix operations

postfix-op     = "(" [arg-list] ")"  ; call
                 / "." "[" [expr-list] "]"  ; index
                 / "." "{" [rec-lit-fields] "}"  ; record literal
                 / "." field-target  ; field access
                 / "?." field-target  ; optional chaining
                 / "!." field-target  ; forced unwrap access
                 / "?"  ; try / propagate
                 / "!"  ; force unwrap
                 / ":?" ast-ty-named ["as" ident]  ; type test
                 / ":?>" ast-ty-named  ; type cast
; §2.4  Atoms - each alternative has a unique FIRST token
ast-expr-atom = lit  ; "("
                / ident
                / ast-paren
                / ast-array  ; "["
                / ast-rec-lit  ; ".{"
                / ast-dot-pfx  ; "."
                / ast-match  ; "match"
                / ast-let  ; "let"
                / ast-return  ; "return"
                / ast-defer  ; "defer"
                / ast-try  ; "try"
                / ast-import  ; "import"
                / ast-choice  ; "choice"
                / ast-record  ; "record"
                / ast-do  ; "do"
                / ast-handle  ; "with"
                / ast-with-attrs  ; "#["
; §2.5  Parenthesised forms
;
;   ()       unit
;   (,)      empty tuple
;   (;)      empty sequence, evaluates to ()
;   (a)      parenthesised expr
;   (a,)     single-element tuple
;   (a, b)   tuple
;   (a; b)   sequence, returns b
;   (a; b;)  sequence, trailing ;, returns ()
;   (e if g | e if g)   piecewise
;
;   When fn-tail is present, paren contents are reinterpreted as lambda
;   parameters.  "=>" is the sole value-level arrow.  "->" and "~>" are
;   type-only arrows.
ast-paren  = "(" paren-body ")" [fn-tail]

fn-tail    = [":" ast-ty] "=>" ast-expr

paren-body = <empty>  ; unit: ()
             / ","  ; empty tuple: (,)
             / ";"  ; empty sequence: (;)
             / ast-expr paren-cont

paren-cont = <empty>  ; parenthesised expr
             / "," [expr-list] [","]  ; tuple
             / ";" [seq-tail]  ; sequence
             / "if" pw-guard *("|" pw-arm)  ; piecewise

seq-tail   = <empty>  ; trailing ;, returns ()
             / ast-expr seq-cont

seq-cont   = <empty>  ; returns last expr
             / ";" [seq-tail]  ; continue sequence
; §2.6  Piecewise - sole conditional form. No if/else. No ternary.
pw-arm            = ast-expr "if" pw-guard

pw-guard          = "_"  ; §2.7  Match
                    / ast-expr

ast-match         = "match" ast-expr "(" match-arm *("|" match-arm) ")"

match-arm         = [attrs] ast-pat ["if" ast-expr] "=>" ast-expr  ; §2.8  Arrays

ast-array         = "[" [array-items] "]"

array-items       = array-item *("," array-item)

array-item        = spread  ; §2.9  Record literals
                    / ast-expr

ast-rec-lit       = ".{" [rec-lit-fields] "}"

rec-lit-fields    = rec-lit-field *("," rec-lit-field)

rec-lit-field     = ident [":=" ast-expr]  ; §2.10  Bindings
                    / spread

ast-let           = "let" ["mut"] ast-pat [ty-params] [with-clause] [ty-annot] (":=" ast-expr ["in" "(" ast-expr ")"] / <stub>)

bracket-params    = "[" ty-ident *("," ty-ident) "]"

with-clause       = "with" effect-set  ; §2.11  Type definitions

ast-choice        = "choice" "{" ast-ty "}"

ast-record        = "record" "{" rec-def-fields "}"

rec-def-fields    = rec-def-field *(";" rec-def-field)

rec-def-field     = ident ":" ast-ty [":=" ast-expr]  ; §2.12  Other atom forms

ast-dot-pfx       = "." ident ["(" [expr-list] ")"]

ast-return        = "return" [ast-expr]

ast-defer         = "defer" ast-expr

ast-try           = "try" ast-expr

ast-import        = "import" lit-string ["as" ident]

ast-do            = "do" ast-expr-post

ast-handle        = "with" ast-ty-named "{" *(handler-op [";"]) "}" "handle" ast-expr

handler-op        = ident ":" params "=>" ast-expr  ; §2.13  Declarations

ast-with-attrs    = attrs ast-decl

ast-decl          = "export" export-tail
                    / ast-let
                    / ast-class-decl
                    / ast-instance-decl
                    / ast-effect-decl
                    / ast-foreign-decl

export-tail       = ast-let
                    / "{" export-list "}" [":=" ast-import]

export-list       = export-item *("," export-item)

export-item       = ident ["as" ident]

ast-class-decl    = "class" ident [ty-params] "{" *(class-member) "}"

ast-instance-decl = "instance" ast-ty-named [ty-params] "{" *(class-member) "}"

ast-effect-decl   = "effect" ident [bracket-params] "{" *(effect-op [";"]) "}"

ast-foreign-decl  = "foreign" [lit-string] ("let" foreign-binding / "(" *("let" foreign-binding ";") ")")

class-member      = (fn-decl / law-decl) [";"]

fn-decl           = "let" op-or-ident params [ty-annot] [":=" ast-expr]

law-decl          = "law" ident [params] ":=" ast-expr

op-or-ident       = ident
                    / op-ident

foreign-binding   = ident ["as" lit-string] [":" ast-ty]

effect-op         = ["fatal"] ident ":" ast-ty  ; §2.14  Types

ast-ty            = ast-ty-arrow

ast-ty-arrow      = ast-ty-sum [("->" / "~>") ast-ty-arrow]

ast-ty-sum        = ast-ty-prod *("+" ast-ty-prod)

ast-ty-prod       = ast-ty-base *("*" ast-ty-base)

ast-ty-base       = ty-ident  ; 'T
                    / "?" ast-ty-base  ; ?T - option sugar
                    / ident ["of" ty-arg-list]  ; Named, Named of T
                    / "(" ast-ty ")"  ; grouped type
                    / "[" [lit-int] "]" ast-ty  ; array type

ty-arg-list       = ast-ty *("," ast-ty)

ty-annot          = ":" ast-ty

ast-ty-named      = ident ["of" ty-arg-list]

effect-set        = "{" effect-list "}"

effect-list       = effect-item *("," effect-item)

effect-item       = ident ["of" ast-ty]
                    / ty-ident

where-clause      = "where" constraint *("," constraint)

constraint        = ty-ident ("<:" / ":>") ast-ty-named  ; §2.15  Patterns

ast-pat           = ast-pat-primary ["or" ast-pat-primary *("or" ast-pat-primary)]

ast-pat-primary   = "_"  ; wildcard
                    / lit  ; literal
                    / ident [pat-suffix]  ; bind, destructor, or named record
                    / "." ident ["(" [pat-list] ")"]  ; UDN variant
                    / ".{" [rec-pat-fields] "}"  ; record pattern
                    / "(" [pat-list] ")"  ; tuple / grouped pattern
                    / "[" [pat-list] "]"  ; array pattern

pat-suffix        = "(" [pat-list] ")"
                    / "{" [rec-pat-fields] "}"

rec-pat-fields    = rec-pat-field *("," rec-pat-field)

rec-pat-field     = ["mut"] ident [":" ast-pat]

pat-list          = ast-pat *("," ast-pat)  ; §2.16  Attributes

attrs             = 1*attr

attr              = "#[" attr-body "]"

attr-body         = ident [":=" attr-value / "(" attr-named-fields ")"]

attr-value        = lit
                    / "(" lit *("," lit) ")"

attr-named-fields = attr-named-field *("," attr-named-field)

attr-named-field  = ident ":=" lit  ; §2.17  Shared helpers

spread            = "..." ast-expr

field-target      = ident
                    / lit-int

ty-params         = [bracket-params] [where-clause]

expr-list         = ast-expr *("," ast-expr)

arg-list          = arg *("," arg)

arg               = spread
                    / ast-expr

params            = "(" [param-list] ")"

param-list        = param *("," param)

param             = ["mut"] ident [ty-annot] [":=" ast-expr]
