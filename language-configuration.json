{
	"comments": {
		"blockComment": [
			"(*",
			"*)"
		]
	},
	"brackets": [
		["(", ")"],
		["[", "]"],
		["{", "}"]
	],
	"autoClosingPairs": [
		{ "open": "(", "close": ")" },
		{ "open": "[", "close": "]" },
		{ "open": "{", "close": "}" },
		{ "open": "'", "close": "'" },
		{ "open": "\"", "close": "\"" },
		{ "open": "(*", "close": "*)" },
		{ "open": "?", "close": "?" }
	],
	"surroundingPairs": [
		["(", ")"],
		["[", "]"],
		["{", "}"],
		["'", "'"],
		["\"", "\""],
		["(*", "*)"],
		["?", "?"]
	],
	"wordPattern": "[a-zA-Z][a-zA-Z0-9-]*"
}
